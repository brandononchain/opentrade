# ─── OpenTrade Multi-LLM Configuration ───────────────────────────
#
# Set LLM_MODEL to choose your model. Only the API key for that
# provider needs to be set. Default: claude-sonnet
#
# Available models:
#   claude-opus, claude-sonnet, claude-haiku     (Anthropic)
#   gpt-4.1, gpt-4.1-mini, o3, o4-mini          (OpenAI)
#   gemini-2.5-pro, gemini-2.5-flash             (Google)
#   qwen-max, qwen-plus, qwen-turbo             (Alibaba Qwen)
#   deepseek-chat, deepseek-reasoner            (DeepSeek)
#   minimax                                      (MiniMax)
#
LLM_MODEL=claude-sonnet

# ─── Provider API Keys (only set the one you use) ────────────────

# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT, o-series) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google (Gemini) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Alibaba Qwen — https://dashscope.console.aliyun.com/
QWEN_API_KEY=

# DeepSeek — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# MiniMax — https://www.minimaxi.chat/
MINIMAX_API_KEY=
